const IMG_FILTERS = [
  'CHROME SHINE','CARBON FIBER','RACING STRIPES','NEON UNDERGLOW',
  'JDM POSTER','INITIAL D','SMOKE TRAIL','ENGINE BAY',
  'POLAROID','NIGHT TOKYO','TIRE BURN','SPEED LINES',
  'HOLOGRAPHIC','DRIFT SMOKE','LENS DIRT','ANAMORPHIC FLARE',
  'HALFTONE','GLITCH RGB','VIGNETTE+GRAIN'
];

const imgFiltersBox = document.getElementById('imgFilters');
const imgState = { filter: null, img: null, bri:100, con:100, sat:100, hue:0, blur:0, exp:0 };

IMG_FILTERS.forEach(name => {
  const btn = document.createElement('button');
  btn.className = 'fbtn';
  btn.textContent = name;
  btn.addEventListener('click', () => {
    imgState.filter = (imgState.filter === name) ? null : name;
    imgFiltersBox.querySelectorAll('.fbtn').forEach(b => b.classList.toggle('active', b.textContent === imgState.filter));
    renderImage();
  });
  imgFiltersBox.appendChild(btn);
});

const imgDrop = document.getElementById('imgDrop');
const imgFile = document.getElementById('imgFile');
const imgPreview = document.getElementById('imgPreview');

imgDrop.addEventListener('click', () => imgFile.click());
imgDrop.addEventListener('dragover', e => { e.preventDefault(); imgDrop.classList.add('dragover'); });
imgDrop.addEventListener('dragleave', () => imgDrop.classList.remove('dragover'));
imgDrop.addEventListener('drop', e => {
  e.preventDefault(); imgDrop.classList.remove('dragover');
  if (e.dataTransfer.files[0]) loadImage(e.dataTransfer.files[0]);
});
imgFile.addEventListener('change', e => { if (e.target.files[0]) loadImage(e.target.files[0]); });

function loadImage(file) {
  const url = URL.createObjectURL(file);
  const img = new Image();
  img.onload = () => {
    imgState.img = img;
    setupImgCanvas();
    renderImage();
  };
  img.src = url;
}

let imgCanvas, imgCtx;
function setupImgCanvas() {
  imgPreview.innerHTML = '';
  imgCanvas = document.createElement('canvas');
  imgCtx = imgCanvas.getContext('2d');
  const maxW = 900, maxH = 560;
  let w = imgState.img.naturalWidth, h = imgState.img.naturalHeight;
  const scale = Math.min(maxW / w, maxH / h, 1);
  imgCanvas.width = Math.floor(w * scale);
  imgCanvas.height = Math.floor(h * scale);
  imgPreview.appendChild(imgCanvas);
}

[['sliBri','bri','lblBri','%'],['sliCon','con','lblCon','%'],['sliSat','sat','lblSat','%'],
 ['sliHue','hue','lblHue','°'],['sliBlur','blur','lblBlur','px'],['sliExp','exp','lblExp','']]
.forEach(([s, key, lab, suf]) => {
  const el = document.getElementById(s);
  el.addEventListener('input', () => {
    imgState[key] = +el.value;
    document.getElementById(lab).textContent = el.value + suf;
    renderImage();
  });
});

document.getElementById('imgReset').addEventListener('click', () => {
  imgState.filter = null;
  imgState.bri=100; imgState.con=100; imgState.sat=100; imgState.hue=0; imgState.blur=0; imgState.exp=0;
  ['sliBri','sliCon','sliSat'].forEach(id => document.getElementById(id).value = 100);
  ['sliHue','sliBlur','sliExp'].forEach(id => document.getElementById(id).value = 0);
  ['lblBri','lblCon','lblSat'].forEach(id => document.getElementById(id).textContent = '100%');
  document.getElementById('lblHue').textContent = '0°';
  document.getElementById('lblBlur').textContent = '0px';
  document.getElementById('lblExp').textContent = '0';
  imgFiltersBox.querySelectorAll('.fbtn').forEach(b => b.classList.remove('active'));
  renderImage();
});

document.getElementById('imgExport').addEventListener('click', () => {
  if (!imgCanvas) return alert('Load an image first');
  const a = document.createElement('a');
  a.download = 'garage_fx_' + Date.now() + '.png';
  a.href = imgCanvas.toDataURL('image/png');
  a.click();
  beep(800, 0.15, 'square', 0.08);
});

function renderImage() {
  if (!imgState.img || !imgCanvas) return;
  const c = imgCanvas, ctx = imgCtx, w = c.width, h = c.height;
  ctx.save();
  ctx.filter = `brightness(${imgState.bri}%) contrast(${imgState.con}%) saturate(${imgState.sat}%) hue-rotate(${imgState.hue}deg) blur(${imgState.blur}px)`;
  ctx.drawImage(imgState.img, 0, 0, w, h);
  ctx.restore();
  if (imgState.exp !== 0) applyExposure(ctx, w, h, imgState.exp);
  if (imgState.filter) applyImgFilter(ctx, w, h, imgState.filter);
}

function applyExposure(ctx, w, h, exp) {
  const data = ctx.getImageData(0, 0, w, h);
  const d = data.data;
  const adj = exp * 1.28;
  for (let i = 0; i < d.length; i += 4) {
    d[i] = Math.max(0, Math.min(255, d[i] + adj));
    d[i+1] = Math.max(0, Math.min(255, d[i+1] + adj));
    d[i+2] = Math.max(0, Math.min(255, d[i+2] + adj));
  }
  ctx.putImageData(data, 0, 0);
}

function applyImgFilter(ctx, w, h, name) {
  switch(name) {
    case 'CHROME SHINE': {
      const grad = ctx.createLinearGradient(0, 0, 0, h);
      grad.addColorStop(0, 'rgba(255,255,255,0.35)');
      grad.addColorStop(0.3, 'rgba(180,200,220,0.1)');
      grad.addColorStop(0.55, 'rgba(255,255,255,0.45)');
      grad.addColorStop(0.8, 'rgba(40,60,80,0.2)');
      grad.addColorStop(1, 'rgba(255,255,255,0.25)');
      ctx.globalCompositeOperation = 'overlay';
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, w, h);
      ctx.globalCompositeOperation = 'source-over';
      break;
    }
    case 'CARBON FIBER': {
      ctx.globalAlpha = 0.55;
      ctx.globalCompositeOperation = 'multiply';
      const tile = 8;
      for (let y = 0; y < h; y += tile) {
        for (let x = 0; x < w; x += tile) {
          ctx.fillStyle = ((x/tile + y/tile) % 2 === 0) ? '#0a0a0a' : '#2a2a2a';
          ctx.fillRect(x, y, tile, tile);
          ctx.fillStyle = 'rgba(255,255,255,0.04)';
          ctx.fillRect(x, y, tile/2, tile/2);
          ctx.fillRect(x+tile/2, y+tile/2, tile/2, tile/2);
        }
      }
      ctx.globalAlpha = 1; ctx.globalCompositeOperation = 'source-over';
      break;
    }
    case 'RACING STRIPES': {
      const sw = w * 0.08;
      ctx.fillStyle = 'rgba(255,255,255,0.85)';
      ctx.fillRect(w/2 - sw - 6, 0, sw, h);
      ctx.fillRect(w/2 + 6, 0, sw, h);
      ctx.fillStyle = 'rgba(0,0,0,0.4)';
      ctx.fillRect(w/2 - sw - 8, 0, 2, h);
      ctx.fillRect(w/2 + sw + 6, 0, 2, h);
      ctx.fillRect(w/2 - 8, 0, 2, h);
      ctx.fillRect(w/2 + 4, 0, 2, h);
      break;
    }
    case 'NEON UNDERGLOW': {
      const grad = ctx.createRadialGradient(w/2, h*1.1, 0, w/2, h*1.1, w*0.7);
      grad.addColorStop(0, 'rgba(255,42,109,0.7)');
      grad.addColorStop(0.4, 'rgba(255,42,109,0.4)');
      grad.addColorStop(1, 'rgba(255,42,109,0)');
      ctx.globalCompositeOperation = 'screen';
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, w, h);
      const grad2 = ctx.createRadialGradient(w/2, h*1.1, 0, w/2, h*1.1, w*0.5);
      grad2.addColorStop(0, 'rgba(5,217,232,0.5)');
      grad2.addColorStop(1, 'rgba(5,217,232,0)');
      ctx.fillStyle = grad2;
      ctx.fillRect(0, 0, w, h);
      ctx.globalCompositeOperation = 'source-over';
      break;
    }
    case 'JDM POSTER': {
      const data = ctx.getImageData(0,0,w,h);
      const d = data.data;
      for (let i = 0; i < d.length; i += 4) {
        d[i] = Math.min(255, d[i]*1.2 + 30);
        d[i+1] = Math.min(255, d[i+1]*0.9 + 10);
        d[i+2] = Math.min(255, d[i+2]*1.15 + 20);
      }
      ctx.putImageData(data, 0, 0);
      ctx.fillStyle = 'rgba(255,42,109,0.18)';
      ctx.fillRect(0, 0, w, h);
      ctx.strokeStyle = 'rgba(255,255,255,0.6)';
      ctx.lineWidth = 4;
      ctx.strokeRect(8, 8, w-16, h-16);
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 24px Orbitron, sans-serif';
      ctx.fillText('JDM', 16, h - 16);
      break;
    }
    case 'INITIAL D': {
      const data = ctx.getImageData(0,0,w,h);
      const d = data.data;
      for (let i = 0; i < d.length; i += 4) {
        const r = d[i], g = d[i+1], b = d[i+2];
        const avg = (r+g+b)/3;
        const step = avg < 80 ? 0 : (avg < 160 ? 128 : 220);
        d[i] = step; d[i+1] = step; d[i+2] = step;
      }
      ctx.putImageData(data, 0, 0);
      ctx.globalCompositeOperation = 'lighten';
      ctx.fillStyle = 'rgba(255,180,200,0.15)';
      ctx.fillRect(0, 0, w, h);
      ctx.globalCompositeOperation = 'source-over';
      // speed lines
      ctx.strokeStyle = 'rgba(255,255,255,0.4)';
      ctx.lineWidth = 1;
      for (let i = 0; i < 30; i++) {
        ctx.beginPath();
        const y = Math.random() * h;
        ctx.moveTo(0, y); ctx.lineTo(w * Math.random(), y);
        ctx.stroke();
      }
      break;
    }
    case 'SMOKE TRAIL': {
      for (let i = 0; i < 18; i++) {
        const x = Math.random() * w;
        const y = h - Math.random() * (h*0.6);
        const r = 30 + Math.random()*120;
        const g = ctx.createRadialGradient(x, y, 0, x, y, r);
        g.addColorStop(0, `rgba(200,200,210,${0.1 + Math.random()*0.2})`);
        g.addColorStop(1, 'rgba(200,200,210,0)');
        ctx.fillStyle = g;
        ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI*2); ctx.fill();
      }
      break;
    }
    case 'ENGINE BAY': {
      const data = ctx.getImageData(0,0,w,h);
      const d = data.data;
      for (let i = 0; i < d.length; i += 4) {
        const avg = (d[i]+d[i+1]+d[i+2])/3;
        const contrasted = ((avg - 128) * 1.8) + 128;
        const v = Math.max(0, Math.min(255, contrasted));
        d[i] = v*0.95; d[i+1] = v*0.85; d[i+2] = v*0.75;
      }
      ctx.putImageData(data, 0, 0);
      // soot grain
      for (let i = 0; i < 1200; i++) {
        ctx.fillStyle = `rgba(0,0,0,${Math.random()*0.3})`;
        ctx.fillRect(Math.random()*w, Math.random()*h, 1, 1);
      }
      break;
    }
    case 'POLAROID': {
      const data = ctx.getImageData(0,0,w,h);
      const d = data.data;
      for (let i = 0; i < d.length; i += 4) {
        d[i] = Math.min(255, d[i]*0.95 + 20);
        d[i+1] = Math.min(255, d[i+1]*0.92 + 10);
        d[i+2] = Math.min(255, d[i+2]*0.85);
      }
      ctx.putImageData(data, 0, 0);
      ctx.fillStyle = '#f5e6c8';
      ctx.fillRect(0, 0, w, 18);
      ctx.fillRect(0, h-50, w, 50);
      ctx.fillRect(0, 0, 18, h);
      ctx.fillRect(w-18, 0, 18, h);
      ctx.fillStyle = '#444';
      ctx.font = '14px Rajdhani';
      ctx.fillText('GARAGE FX // SHOT', 26, h - 24);
      break;
    }
    case 'NIGHT TOKYO': {
      const data = ctx.getImageData(0,0,w,h);
      const d = data.data;
      for (let i = 0; i < d.length; i += 4) {
        d[i] = d[i]*0.5;
        d[i+1] = d[i+1]*0.55 + 5;
        d[i+2] = Math.min(255, d[i+2]*1.1 + 30);
      }
      ctx.putImageData(data, 0, 0);
      ctx.globalCompositeOperation = 'screen';
      for (let i = 0; i < 25; i++) {
        const x = Math.random()*w, y = Math.random()*h;
        const r = 6 + Math.random()*30;
        const c = Math.random() < 0.5 ? 'rgba(255,42,109,0.7)' : 'rgba(5,217,232,0.7)';
        const g = ctx.createRadialGradient(x, y, 0, x, y, r);
        g.addColorStop(0, c); g.addColorStop(1, 'transparent');
        ctx.fillStyle = g; ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI*2); ctx.fill();
      }
      ctx.globalCompositeOperation = 'source-over';
      break;
    }
    case 'TIRE BURN': {
      ctx.globalCompositeOperation = 'multiply';
      ctx.fillStyle = 'rgba(50,30,30,0.6)';
      ctx.fillRect(0, h*0.7, w, h*0.3);
      ctx.globalCompositeOperation = 'source-over';
      // skid marks
      ctx.strokeStyle = 'rgba(20,20,20,0.7)';
      ctx.lineWidth = 8;
      for (let i = 0; i < 3; i++) {
        ctx.beginPath();
        ctx.moveTo(Math.random()*w, h);
        ctx.bezierCurveTo(w*0.3, h*0.7, w*0.7, h*0.8, w*Math.random(), h);
        ctx.stroke();
      }
      break;
    }
    case 'SPEED LINES': {
      ctx.strokeStyle = 'rgba(255,255,255,0.6)';
      ctx.lineWidth = 2;
      const cx = w/2, cy = h/2;
      for (let i = 0; i < 70; i++) {
        const ang = Math.random()*Math.PI*2;
        const r1 = 80 + Math.random()*120;
        const r2 = r1 + 40 + Math.random()*220;
        ctx.beginPath();
        ctx.moveTo(cx + Math.cos(ang)*r1, cy + Math.sin(ang)*r1);
        ctx.lineTo(cx + Math.cos(ang)*r2, cy + Math.sin(ang)*r2);
        ctx.stroke();
      }
      break;
    }
    case 'HOLOGRAPHIC': {
      ctx.globalCompositeOperation = 'screen';
      const g = ctx.createLinearGradient(0, 0, w, h);
      g.addColorStop(0, 'rgba(255,42,109,0.35)');
      g.addColorStop(0.33, 'rgba(255,210,63,0.35)');
      g.addColorStop(0.66, 'rgba(5,217,232,0.35)');
      g.addColorStop(1, 'rgba(170,90,255,0.35)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, w, h);
      ctx.globalCompositeOperation = 'source-over';
      break;
    }
    case 'DRIFT SMOKE': {
      ctx.globalCompositeOperation = 'screen';
      for (let i = 0; i < 14; i++) {
        const x = (i/14)*w + Math.random()*60 - 30;
        const y = h - 40 - Math.random()*120;
        const r = 60 + Math.random()*180;
        const g = ctx.createRadialGradient(x, y, 0, x, y, r);
        g.addColorStop(0, 'rgba(255,255,255,0.35)');
        g.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.fillStyle = g;
        ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI*2); ctx.fill();
      }
      ctx.globalCompositeOperation = 'source-over';
      break;
    }
    case 'LENS DIRT': {
      for (let i = 0; i < 60; i++) {
        ctx.fillStyle = `rgba(200,200,200,${0.1 + Math.random()*0.15})`;
        const x = Math.random()*w, y = Math.random()*h;
        ctx.beginPath();
        ctx.arc(x, y, 1 + Math.random()*8, 0, Math.PI*2);
        ctx.fill();
      }
      ctx.fillStyle = 'rgba(255,255,255,0.05)';
      ctx.fillRect(0, 0, w, h);
      break;
    }
    case 'ANAMORPHIC FLARE': {
      ctx.globalCompositeOperation = 'screen';
      const cx = w*0.7, cy = h*0.3;
      const g = ctx.createLinearGradient(0, cy, w, cy);
      g.addColorStop(0, 'rgba(5,217,232,0)');
      g.addColorStop(0.5, 'rgba(5,217,232,0.6)');
      g.addColorStop(1, 'rgba(5,217,232,0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, cy - 4, w, 8);
      const g2 = ctx.createRadialGradient(cx, cy, 0, cx, cy, 80);
      g2.addColorStop(0, 'rgba(255,255,255,0.8)');
      g2.addColorStop(1, 'rgba(255,255,255,0)');
      ctx.fillStyle = g2;
      ctx.beginPath(); ctx.arc(cx, cy, 80, 0, Math.PI*2); ctx.fill();
      ctx.globalCompositeOperation = 'source-over';
      break;
    }
    case 'HALFTONE': {
      const data = ctx.getImageData(0,0,w,h);
      const d = data.data;
      ctx.fillStyle = '#fff'; ctx.fillRect(0,0,w,h);
      const step = 6;
      for (let y = 0; y < h; y += step) {
        for (let x = 0; x < w; x += step) {
          const idx = (Math.floor(y)*w + Math.floor(x))*4;
          const lum = (d[idx]+d[idx+1]+d[idx+2])/3 / 255;
          const r = (1 - lum) * step * 0.6;
          ctx.fillStyle = '#111';
          ctx.beginPath(); ctx.arc(x+step/2, y+step/2, r, 0, Math.PI*2); ctx.fill();
        }
      }
      break;
    }
    case 'GLITCH RGB': {
      const data = ctx.getImageData(0,0,w,h);
      const out = ctx.createImageData(w, h);
      const d = data.data, o = out.data;
      const sR = 6, sB = -6;
      for (let y = 0; y < h; y++) {
        for (let x = 0; x < w; x++) {
          const i = (y*w + x)*4;
          const iR = (y*w + Math.min(w-1, Math.max(0, x + sR)))*4;
          const iB = (y*w + Math.min(w-1, Math.max(0, x + sB)))*4;
          o[i] = d[iR];
          o[i+1] = d[i+1];
          o[i+2] = d[iB+2];
          o[i+3] = 255;
        }
      }
      ctx.putImageData(out, 0, 0);
      // glitch slices
      for (let i = 0; i < 6; i++) {
        const y = Math.random()*h;
        const hh = 2 + Math.random()*10;
        const off = (Math.random()-0.5)*30;
        const slice = ctx.getImageData(0, y, w, hh);
        ctx.putImageData(slice, off, y);
      }
      break;
    }
    case 'VIGNETTE+GRAIN': {
      const g = ctx.createRadialGradient(w/2, h/2, Math.min(w,h)*0.3, w/2, h/2, Math.max(w,h)*0.7);
      g.addColorStop(0, 'rgba(0,0,0,0)');
      g.addColorStop(1, 'rgba(0,0,0,0.85)');
      ctx.fillStyle = g; ctx.fillRect(0, 0, w, h);
      for (let i = 0; i < 4000; i++) {
        ctx.fillStyle = `rgba(255,255,255,${Math.random()*0.07})`;
        ctx.fillRect(Math.random()*w, Math.random()*h, 1, 1);
      }
      break;
    }
  }
}

