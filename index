function rebuildCar() {
  if (!T.scene || !THREEx) return;
  if (T.car) { T.scene.remove(T.car); disposeGroup(T.car); }
  const car = new THREEx.Group();
  T.car = car;

  buildCarBody(car);
  buildCarHood(car);
  buildCarWindows(car);
  buildCarSpoiler(car);
  buildCarHeadlights(car);
  buildCarTaillights(car);
  buildCarExhaust(car);
  buildCarBodyKit(car);
  buildCarWheels(car);

  T.scene.add(car);
}

function disposeGroup(g) {
  g.traverse(o => {
    if (o.geometry) o.geometry.dispose();
    if (o.material) {
      if (Array.isArray(o.material)) o.material.forEach(m => m.dispose());
      else o.material.dispose();
    }
  });
}

function bodyMaterial() {
  const THREE = THREEx;
  let met = 0.6, rou = 0.25;
  switch(T.finish) {
    case 'gloss':    met = 0.5; rou = 0.18; break;
    case 'metallic': met = 0.9; rou = 0.28; break;
    case 'matte':    met = 0.05; rou = 0.85; break;
    case 'chrome':   met = 1.0; rou = 0.04; break;
    case 'pearl':    met = 0.7; rou = 0.15; break;
  }
  return new THREE.MeshStandardMaterial({
    color: T.color, metalness: met, roughness: rou,
    envMapIntensity: 1.2
  });
}

function carYOffset() { return T.rideH * 0.012; }

function buildCarBody(g) {
  const THREE = THREEx;
  const mat = bodyMaterial();
  const isWide = T.bodyKit === 'wide';
  const w = isWide ? 1.8 : 1.55;

  const mid = new THREE.Mesh(new THREE.BoxGeometry(3.6, 0.45, w), mat);
  mid.position.y = 0.55 + carYOffset();
  mid.castShadow = true; g.add(mid);

  const shoulder = new THREE.Mesh(new THREE.BoxGeometry(3.5, 0.32, w-0.05), mat);
  shoulder.position.y = 0.85 + carYOffset();
  shoulder.castShadow = true; g.add(shoulder);

  const fenderW = isWide ? w + 0.4 : w + 0.05;
  const fF = new THREE.Mesh(new THREE.BoxGeometry(1.2, 0.7, fenderW), mat);
  fF.position.set(1.1, 0.55 + carYOffset(), 0);
  fF.castShadow = true; g.add(fF);

  const fR = new THREE.Mesh(new THREE.BoxGeometry(1.3, 0.7, fenderW), mat);
  fR.position.set(-1.1, 0.55 + carYOffset(), 0);
  fR.castShadow = true; g.add(fR);

  const hood = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.06, w-0.1), mat);
  hood.position.set(0.9, 0.92 + carYOffset(), 0);
  hood.castShadow = true; g.add(hood);
  T.parts.hood = hood;

  const trunk = new THREE.Mesh(new THREE.BoxGeometry(0.9, 0.06, w-0.1), mat);
  trunk.position.set(-1.45, 0.99 + carYOffset(), 0);
  trunk.castShadow = true; g.add(trunk);

  const cabin = new THREE.Mesh(new THREE.BoxGeometry(1.7, 0.5, w-0.1), mat);
  cabin.position.set(-0.25, 1.22 + carYOffset(), 0);
  cabin.castShadow = true; g.add(cabin);

  const slopeF = new THREE.Mesh(new THREE.BoxGeometry(0.7, 0.04, w-0.15), mat);
  slopeF.position.set(0.5, 1.1 + carYOffset(), 0);
  slopeF.rotation.z = -0.35;
  g.add(slopeF);

  const slopeR = new THREE.Mesh(new THREE.BoxGeometry(0.7, 0.04, w-0.15), mat);
  slopeR.position.set(-1.0, 1.15 + carYOffset(), 0);
  slopeR.rotation.z = 0.42;
  g.add(slopeR);

  if (T.stripe !== 'none') {
    const stripeMat = new THREE.MeshStandardMaterial({ color: T.stripeColor, metalness: 0.3, roughness: 0.3 });
    if (T.stripe === 'center' || T.stripe === 'rally') {
      const sH = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.005, 0.16), stripeMat);
      sH.position.set(0.9, 0.96 + carYOffset(), 0);
      g.add(sH);
      const sT = new THREE.Mesh(new THREE.BoxGeometry(0.9, 0.005, 0.16), stripeMat);
      sT.position.set(-1.45, 1.03 + carYOffset(), 0);
      g.add(sT);
      const sR = new THREE.Mesh(new THREE.BoxGeometry(1.7, 0.005, 0.16), stripeMat);
      sR.position.set(-0.25, 1.48 + carYOffset(), 0);
      g.add(sR);
    }
    if (T.stripe === 'dual' || T.stripe === 'rally') {
      for (const zo of [-0.35, 0.35]) {
        const sH = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.005, 0.12), stripeMat);
        sH.position.set(0.9, 0.96 + carYOffset(), zo);
        g.add(sH);
        const sR = new THREE.Mesh(new THREE.BoxGeometry(1.7, 0.005, 0.12), stripeMat);
        sR.position.set(-0.25, 1.48 + carYOffset(), zo);
        g.add(sR);
      }
    }
  }

  T.parts.bodyMat = mat;
}

function buildCarHood(g) {
  const THREE = THREEx;
  const baseMat = T.parts.bodyMat;
  switch(T.hood) {
    case 'scoop': {
      const s = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.18, 0.55), baseMat);
      s.position.set(0.85, 1.03 + carYOffset(), 0);
      const opening = new THREE.Mesh(
        new THREE.BoxGeometry(0.3, 0.06, 0.4),
        new THREE.MeshStandardMaterial({ color: 0x000000, roughness: 1 })
      );
      opening.position.set(0.75, 1.07 + carYOffset(), 0);
      g.add(s); g.add(opening);
      break;
    }
    case 'vent': {
      const m = new THREE.MeshStandardMaterial({ color: 0x111111, metalness:0.6, roughness:0.5 });
      for (const z of [-0.35, 0.35]) {
        const v = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.02, 0.18), m);
        v.position.set(0.85, 0.97 + carYOffset(), z);
        g.add(v);
      }
      break;
    }
    case 'cowl': {
      const c = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.12, 0.7), baseMat);
      c.position.set(0.55, 1.0 + carYOffset(), 0);
      g.add(c);
      break;
    }
    case 'cf': {
      const cfMat = new THREE.MeshStandardMaterial({ color: 0x080808, metalness: 0.3, roughness: 0.55 });
      const cf = new THREE.Mesh(new THREE.BoxGeometry(1.42, 0.07, 1.42), cfMat);
      cf.position.set(0.9, 0.94 + carYOffset(), 0);
      g.add(cf);
      for (let i = -3; i <= 3; i++) {
        const l = new THREE.Mesh(
          new THREE.BoxGeometry(1.4, 0.002, 0.02),
          new THREE.MeshBasicMaterial({ color: 0x202020 })
        );
        l.position.set(0.9, 0.98 + carYOffset(), i*0.18);
        g.add(l);
      }
      break;
    }
    case 'clear': {
      const cl = new THREE.Mesh(
