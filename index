<!DOCTYPE html>
<html lang="sk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GARAGE FX — Tuning Studio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Rajdhani:wght@400;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
/* =========================================
   GARAGE FX — TUNING STUDIO
   Author: Rudenko Mykhailo (B-MSAP, Časť B)
   ========================================= */

:root {
  --bg: #0a0a0f;
  --bg-2: #14141c;
  --bg-3: #1c1c28;
  --pink: #ff2a6d;
  --cyan: #05d9e8;
  --yellow: #ffd23f;
  --white: #f1f1f5;
  --gray: #6b6b80;
  --hazard-y: #ffcc00;
  --hazard-k: #111111;
  --pink-glow: 0 0 10px #ff2a6d, 0 0 20px #ff2a6d77;
  --cyan-glow: 0 0 10px #05d9e8, 0 0 20px #05d9e877;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  background: var(--bg);
  color: var(--white);
  font-family: 'Rajdhani', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
  cursor: crosshair;
}

body {
  background:
    radial-gradient(ellipse at top, #1a0a1f 0%, #0a0a0f 50%, #050507 100%);
  position: relative;
}

/* Scanlines overlay */
body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background: repeating-linear-gradient(
    0deg,
    rgba(5, 217, 232, 0.03) 0px,
    rgba(5, 217, 232, 0.03) 1px,
    transparent 1px,
    transparent 3px
  );
  z-index: 9998;
  mix-blend-mode: screen;
}

/* CRT vignette */
body::after {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.7) 100%);
  z-index: 9997;
}

#particles {
  position: fixed; inset: 0; z-index: 0;
  pointer-events: none;
}

/* ===== Hazard stripes ===== */
.hazard-bar {
  width: 100%;
  height: 14px;
  background: repeating-linear-gradient(
    -45deg,
    var(--hazard-y) 0,
    var(--hazard-y) 14px,
    var(--hazard-k) 14px,
    var(--hazard-k) 28px
  );
  background-size: 200% 100%;
  animation: hazardMove 4s linear infinite;
  box-shadow: 0 0 12px rgba(255,204,0,0.4);
}

@keyframes hazardMove {
  0% { background-position: 0 0; }
  100% { background-position: 200% 0; }
}

/* ===== Buttons & UI ===== */
button, .btn {
  background: var(--bg-3);
  color: var(--cyan);
  border: 1px solid var(--cyan);
  font-family: 'JetBrains Mono', monospace;
  font-weight: 700;
  text-transform: uppercase;
  font-size: 12px;
  letter-spacing: 1.5px;
  padding: 10px 18px;
  cursor: pointer;
  transition: all .15s ease;
  position: relative;
  overflow: hidden;
}

button:hover, .btn:hover {
  background: var(--cyan);
  color: var(--bg);
  box-shadow: var(--cyan-glow);
  transform: translateY(-1px);
}

button:active { transform: translateY(0); }

button.pink, .btn.pink {
  color: var(--pink);
  border-color: var(--pink);
}

button.pink:hover, .btn.pink:hover {
  background: var(--pink);
  color: var(--bg);
  box-shadow: var(--pink-glow);
}

/* ===== Boot screen ===== */
#boot {
  position: fixed;
  inset: 0;
  background: #050507;
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  font-family: 'JetBrains Mono', monospace;
  color: var(--cyan);
  overflow: hidden;
}

#boot .ecu-logo {
  font-family: 'Orbitron', sans-serif;
  font-size: 56px;
  font-weight: 900;
  color: var(--pink);
  text-shadow: var(--pink-glow);
  letter-spacing: 6px;
  margin-bottom: 30px;
  animation: flickerPink 2.5s infinite;
}

@keyframes flickerPink {
  0%, 18%, 22%, 25%, 53%, 57%, 100% { opacity: 1; }
  20%, 24%, 55% { opacity: 0.4; }
}

#boot .ecu-sub {
  color: var(--cyan);
  font-size: 14px;
  letter-spacing: 4px;
  margin-bottom: 40px;
  text-shadow: var(--cyan-glow);
}

#boot .boot-log {
  width: 600px;
  max-width: 90vw;
  height: 200px;
  background: #07070b;
  border: 1px solid #1c2030;
  padding: 14px;
  font-size: 12px;
  line-height: 1.5;
  overflow: hidden;
  margin-bottom: 22px;
}

#boot .boot-log .line { white-space: nowrap; }
#boot .boot-log .line .ok { color: #43ff7a; }
#boot .boot-log .line .warn { color: var(--yellow); }
#boot .boot-log .line .err { color: var(--pink); }

#boot .progress {
  width: 600px; max-width: 90vw;
  height: 18px;
  border: 1px solid var(--cyan);
  position: relative;
  background: #07070b;
}
#boot .progress .fill {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, var(--cyan), var(--pink));
  box-shadow: 0 0 10px var(--cyan);
  transition: width 80ms linear;
}
#boot .progress .pct {
  position: absolute; right: -52px; top: 0;
  font-family: 'JetBrains Mono', monospace;
  font-size: 14px;
}

#boot .skip {
  margin-top: 30px;
  font-size: 11px;
  color: var(--gray);
}

#boot.gone { display: none; }

/* ===== Top bar ===== */
header.topbar {
  position: relative;
  z-index: 5;
  padding: 22px 36px 14px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #1c1c28;
  background: linear-gradient(180deg, #0a0a0f 60%, transparent 100%);
}

header.topbar .logo {
  font-family: 'Orbitron', sans-serif;
  font-weight: 900;
  font-size: 22px;
  color: var(--pink);
  letter-spacing: 4px;
  text-shadow: var(--pink-glow);
}
header.topbar .logo span { color: var(--cyan); text-shadow: var(--cyan-glow); }

header.topbar .meta {
  display: flex;
  gap: 18px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--gray);
  letter-spacing: 1.5px;
}
header.topbar .meta .ind {
  display: flex; align-items: center; gap: 6px;
}
header.topbar .meta .dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: #43ff7a; box-shadow: 0 0 8px #43ff7a;
  animation: pulse 1.4s infinite;
}
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:.4;} }

/* ===== Main menu ===== */
main { position: relative; z-index: 4; padding: 30px 36px 80px; }

.title-row {
  text-align: center;
  margin: 24px 0 36px;
}
.title-row h1 {
  font-family: 'Orbitron', sans-serif;
  font-weight: 900;
  font-size: 44px;
  letter-spacing: 8px;
  background: linear-gradient(90deg, var(--pink) 0%, var(--cyan) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  filter: drop-shadow(0 0 10px #ff2a6d55);
}
.title-row p {
  margin-top: 8px;
  color: var(--gray);
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  letter-spacing: 4px;
}

.bays {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
  margin: 30px 0;
}

.bay {
  position: relative;
  border: 1px solid #2a2a3a;
  background:
    linear-gradient(135deg, #14141c 0%, #1c1c28 100%);
  padding: 24px 20px 20px;
  cursor: pointer;
  transition: all .2s;
  overflow: hidden;
  min-height: 200px;
}

.bay::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 100% 0%, rgba(255,42,109,0.16) 0%, transparent 60%),
    radial-gradient(circle at 0% 100%, rgba(5,217,232,0.12) 0%, transparent 60%);
  opacity: 0.7;
  transition: opacity .2s;
}
.bay::after {
  content: attr(data-num);
  position: absolute;
  right: 14px; top: 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--gray);
  letter-spacing: 2px;
}
.bay:hover {
  border-color: var(--cyan);
  transform: translateY(-3px);
  box-shadow: 0 8px 32px rgba(5,217,232,.25), inset 0 0 0 1px rgba(5,217,232,.4);
}
.bay:hover::before { opacity: 1.2; }

.bay .ic {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  color: var(--pink);
  letter-spacing: 3px;
  margin-bottom: 10px;
}
.bay h2 {
  font-family: 'Orbitron', sans-serif;
  font-size: 22px;
  font-weight: 700;
  letter-spacing: 3px;
  color: var(--white);
  margin-bottom: 8px;
}
.bay h2 .acc { color: var(--cyan); }
.bay p {
  font-size: 13px;
  color: var(--gray);
  line-height: 1.5;
  margin-bottom: 14px;
}
.bay .enter {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--cyan);
  letter-spacing: 2px;
}
.bay .enter::before { content: "▶ "; }

/* ===== Bay screens (sub-pages) ===== */
.bay-screen { display: none; min-height: 70vh; }
.bay-screen.active { display: block; animation: glitchIn .35s ease; }

@keyframes glitchIn {
  0% { opacity: 0; transform: translateX(-12px) skewX(-3deg); filter: hue-rotate(120deg); }
  60% { opacity: 1; transform: translateX(2px); filter: hue-rotate(20deg); }
  100% { opacity: 1; transform: translateX(0); filter: none; }
}

.bay-screen .bay-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 18px;
  padding-bottom: 10px;
  border-bottom: 1px dashed #2a2a3a;
}
.bay-screen .bay-head h2 {
  font-family: 'Orbitron', sans-serif;
  font-size: 24px;
  letter-spacing: 4px;
  color: var(--pink);
  text-shadow: var(--pink-glow);
}
.bay-screen .bay-head .crumbs {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--gray);
  letter-spacing: 2px;
}

.workshop {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 18px;
  align-items: start;
}
@media (max-width: 900px) {
  .workshop { grid-template-columns: 1fr; }
}

.panel {
  background: var(--bg-2);
  border: 1px solid #2a2a3a;
  padding: 16px;
  position: relative;
}
.panel .panel-title {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--cyan);
  letter-spacing: 3px;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 1px dashed #2a2a3a;
}
.panel .panel-title::before { content: "// "; color: var(--gray); }

.dropzone {
  border: 2px dashed #2a2a3a;
  padding: 24px;
  text-align: center;
  margin-bottom: 14px;
  background: #07070b;
  transition: all .2s;
  cursor: pointer;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  color: var(--gray);
  letter-spacing: 1.5px;
}
.dropzone:hover, .dropzone.dragover {
  border-color: var(--pink);
  color: var(--pink);
  background: #1a0a14;
  box-shadow: inset 0 0 20px rgba(255,42,109,.2);
}
.dropzone strong { color: var(--cyan); display: block; margin-bottom: 6px; font-size: 14px; }

.filter-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
  margin-bottom: 14px;
  max-height: 280px;
  overflow-y: auto;
}
.filter-list::-webkit-scrollbar { width: 6px; }
.filter-list::-webkit-scrollbar-track { background: #07070b; }
.filter-list::-webkit-scrollbar-thumb { background: var(--cyan); }

.fbtn {
  padding: 7px 8px;
  font-size: 10px;
  letter-spacing: 1px;
  text-align: center;
}

.fbtn.active {
  background: var(--pink);
  color: var(--bg);
  border-color: var(--pink);
  box-shadow: var(--pink-glow);
}

.sliders { margin-top: 8px; }
.slider-row {
  margin: 10px 0;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--gray);
}
.slider-row label {
  display: flex;
  justify-content: space-between;
  letter-spacing: 1.5px;
  margin-bottom: 4px;
}
.slider-row label span { color: var(--cyan); }
.slider-row input[type="range"] {
  width: 100%;
  -webkit-appearance: none;
  background: #07070b;
  height: 4px;
  outline: none;
  border: 1px solid #2a2a3a;
}
.slider-row input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 14px; height: 14px;
  background: var(--pink);
  border: 1px solid #fff;
  cursor: pointer;
  box-shadow: var(--pink-glow);
}
.slider-row input[type="range"]::-moz-range-thumb {
  width: 14px; height: 14px;
  background: var(--pink);
  border: 1px solid #fff;
  cursor: pointer;
}

.preview {
  background: #050507;
  border: 1px solid #2a2a3a;
  min-height: 480px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.preview .empty {
  color: var(--gray);
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: 2px;
  font-size: 13px;
  text-align: center;
}
.preview .empty::before {
  content: "[ NO MEDIA LOADED ]";
  color: var(--pink); display: block; margin-bottom: 8px;
  text-shadow: var(--pink-glow);
}
.preview canvas, .preview video, .preview img {
  max-width: 100%;
  max-height: 580px;
  display: block;
}

.action-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }

/* ===== Audio bay specific ===== */
.audio-vis {
  width: 100%;
  height: 220px;
  background: #050507;
  border: 1px solid #2a2a3a;
  margin-top: 10px;
}

.rpm-gauge {
  width: 180px; height: 180px;
  border-radius: 50%;
  border: 4px solid #2a2a3a;
  position: relative;
  margin: 0 auto;
}

/* ===== 3D bay specific ===== */
#three-container {
  width: 100%;
  min-height: 560px;
  height: 560px;
  background: #050507;
  border: 1px solid #2a2a3a;
  position: relative;
}
#three-container canvas { display: block; width: 100% !important; height: 100% !important; }

/* ===== Text bay specific ===== */
.text-render-area {
  min-height: 460px;
  background: #050507;
  border: 1px solid #2a2a3a;
  padding: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: auto;
}

/* ===== Footer / back button ===== */
footer.botbar {
  position: relative;
  z-index: 5;
  margin-top: 40px;
  padding: 24px 36px;
  border-top: 1px solid #1c1c28;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
  background: linear-gradient(0deg, #0a0a0f 60%, transparent 100%);
}
footer.botbar .author {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--gray);
  letter-spacing: 2px;
}
footer.botbar .author strong { color: var(--cyan); }

/* ===== Glitch transition layer ===== */
#glitch-fx {
  position: fixed;
  inset: 0;
  z-index: 9000;
  pointer-events: none;
  opacity: 0;
}
#glitch-fx.on {
  opacity: 1;
  background:
    repeating-linear-gradient(0deg, transparent 0, transparent 3px, rgba(255,42,109,.18) 3px, rgba(255,42,109,.18) 4px),
    repeating-linear-gradient(0deg, transparent 0, transparent 7px, rgba(5,217,232,.18) 7px, rgba(5,217,232,.18) 8px);
  animation: glitchHard .35s steps(4) 1;
}
@keyframes glitchHard {
  0% { transform: translateX(0); }
  25% { transform: translateX(-10px); filter: hue-rotate(80deg); }
  50% { transform: translateX(10px); filter: hue-rotate(-80deg); }
  75% { transform: translateX(-4px); }
  100% { transform: translateX(0); }
}

/* ===== License plate text bay output ===== */
.license-plate {
  display: inline-block;
  background: #fff;
  color: #111;
  font-family: 'Orbitron', sans-serif;
  font-weight: 900;
  font-size: 64px;
  letter-spacing: 8px;
  padding: 16px 30px;
  border: 4px solid #111;
  border-radius: 8px;
  box-shadow: 0 0 0 4px #ccc, 0 8px 24px rgba(0,0,0,0.7);
  position: relative;
}
.license-plate.eu::before {
  content: "EU\\ASK";
  position: absolute;
  left: 0; top: 0; bottom: 0; width: 30px;
  background: #003399;
  color: #ffcc00;
  font-size: 10px;
  display: flex; align-items: center; justify-content: center;
  white-space: pre-line;
  text-align: center;
  border-radius: 4px 0 0 4px;
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: 0;
}

.neon-text {
  font-family: 'Orbitron', sans-serif;
  font-size: 60px;
  font-weight: 700;
  letter-spacing: 4px;
  color: #fff;
  text-shadow:
    0 0 4px #fff,
    0 0 10px var(--pink),
    0 0 22px var(--pink),
    0 0 40px var(--pink),
    0 0 80px var(--pink);
  animation: neonFlick 3s infinite alternate;
}
@keyframes neonFlick {
  0%, 18%, 22%, 25%, 53%, 57%, 100% {
    text-shadow:
      0 0 4px #fff,
      0 0 10px var(--pink),
      0 0 22px var(--pink),
      0 0 40px var(--pink),
      0 0 80px var(--pink);
  }
  20%, 24%, 55% { text-shadow: none; opacity: 0.6; }
}

.racing-text {
  font-family: 'Orbitron', sans-serif;
  font-weight: 900;
  font-size: 90px;
  background: linear-gradient(180deg, #ff2a6d 0%, #ffcc00 50%, #05d9e8 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: 6px;
  transform: skewX(-12deg);
  filter: drop-shadow(4px 6px 0 #111) drop-shadow(0 0 20px #ff2a6d55);
}

.speedo-text {
  font-family: 'Orbitron', sans-serif;
  font-size: 120px;
  font-weight: 900;
  color: var(--cyan);
  text-shadow: var(--cyan-glow);
  letter-spacing: 12px;
  font-variant-numeric: tabular-nums;
}

.ascii-art {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  line-height: 1.05;
  color: var(--cyan);
  white-space: pre;
  text-shadow: var(--cyan-glow);
}

/* ===== Misc helpers ===== */
.kv {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--gray);
  letter-spacing: 1.5px;
  margin: 4px 0;
}
.kv strong { color: var(--cyan); }

.hidden { display: none !important; }

#main-menu.hidden, .bay-screen { /* explicit */ }

/* tiny color swatch grid */
.color-grid { display: flex; flex-wrap: wrap; gap: 6px; }
.color-grid .sw {
  width: 26px; height: 26px;
  border: 2px solid #2a2a3a;
  cursor: pointer;
  transition: all .15s;
}
.color-grid .sw.active {
  border-color: var(--pink);
  box-shadow: var(--pink-glow);
  transform: scale(1.1);
}

/* environment selector */
.env-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
.env-grid .envbtn {
  font-size: 10px; padding: 6px;
}

/* ===== TUNER GARAGE LAYOUT ===== */
.tuner {
  display: grid;
  grid-template-columns: 340px 1fr;
  gap: 18px;
  align-items: start;
}
@media (max-width: 980px) { .tuner { grid-template-columns: 1fr; } }

.tuner-left {
  background: var(--bg-2);
  border: 1px solid #2a2a3a;
  position: relative;
}

.tuner-tabs {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  border-bottom: 1px solid #2a2a3a;
  background: #07070b;
}
.t-tab {
  padding: 8px 4px;
  text-align: center;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  letter-spacing: 1px;
  color: var(--gray);
  cursor: pointer;
  border-right: 1px solid #1a1a26;
  border-bottom: 2px solid transparent;
  transition: all .15s;
  user-select: none;
}
.t-tab:hover { color: var(--cyan); background: #0e0e16; }
.t-tab.active {
  color: var(--pink);
  border-bottom-color: var(--pink);
  background: #14141c;
  text-shadow: var(--pink-glow);
}

.t-panel {
  display: none;
  padding: 14px;
  min-height: 360px;
}
.t-panel.active { display: block; animation: fadeIn .2s; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; } }

.opt-row {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin: 6px 0;
}
.opt {
  padding: 6px 9px;
  font-size: 10px;
  letter-spacing: 1px;
  background: #07070b;
  color: var(--gray);
  border: 1px solid #2a2a3a;
}
.opt:hover {
  color: var(--cyan);
  border-color: var(--cyan);
  background: #07070b;
  box-shadow: none;
  transform: none;
}
.opt.active {
  background: var(--pink);
  color: #fff;
