function setupGarage() {
  const THREE = THREEx;
  const cont = document.getElementById('three-container');
  document.getElementById('threeEmpty').style.display = 'none';

  const scene = new THREE.Scene();
  scene.fog = new THREE.Fog(0x0a0a14, 12, 30);
  scene.background = new THREE.Color(T.env[1]);

  const camera = new THREE.PerspectiveCamera(40, cont.clientWidth/cont.clientHeight, 0.1, 200);
  applyOrbitCamera(camera);

  const renderer = new THREE.WebGLRenderer({ antialias: true, preserveDrawingBuffer: true });
  renderer.setSize(cont.clientWidth, cont.clientHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  cont.appendChild(renderer.domElement);

  T.scene = scene; T.camera = camera; T.renderer = renderer;

  buildLights();
  buildGarage();
  rebuildCar();
  applyEnv();

  const dom = renderer.domElement;
  dom.style.cursor = 'grab';
  dom.addEventListener('mousedown', e => {
    T.orbit.dragging = true; T.orbit.lx = e.clientX; T.orbit.ly = e.clientY;
    dom.style.cursor = 'grabbing';
  });
  window.addEventListener('mouseup', () => { T.orbit.dragging = false; dom.style.cursor = 'grab'; });
  window.addEventListener('mousemove', e => {
    if (!T.orbit.dragging) return;
    const dx = e.clientX - T.orbit.lx;
    const dy = e.clientY - T.orbit.ly;
    T.orbit.lx = e.clientX; T.orbit.ly = e.clientY;
    T.orbit.theta -= dx * 0.008;
    T.orbit.phi   -= dy * 0.005;
    T.orbit.phi = Math.max(0.15, Math.min(Math.PI*0.49, T.orbit.phi));
    if (T.cam !== 'orbit') {
      T.cam = 'orbit';
      document.querySelectorAll('#camMode .opt').forEach(b => b.classList.toggle('active', b.dataset.v === 'orbit'));
    }
  });
  dom.addEventListener('wheel', e => {
    e.preventDefault();
    T.orbit.radius += e.deltaY * 0.005;
    T.orbit.radius = Math.max(3, Math.min(18, T.orbit.radius));
  }, { passive: false });
  dom.addEventListener('touchstart', e => {
    if (e.touches.length === 1) {
      T.orbit.dragging = true; T.orbit.lx = e.touches[0].clientX; T.orbit.ly = e.touches[0].clientY;
    }
  });
  dom.addEventListener('touchmove', e => {
    if (T.orbit.dragging && e.touches.length === 1) {
      const dx = e.touches[0].clientX - T.orbit.lx;
      const dy = e.touches[0].clientY - T.orbit.ly;
      T.orbit.lx = e.touches[0].clientX; T.orbit.ly = e.touches[0].clientY;
      T.orbit.theta -= dx * 0.012;
      T.orbit.phi   -= dy * 0.008;
      T.orbit.phi = Math.max(0.15, Math.min(Math.PI*0.49, T.orbit.phi));
    }
  });
  dom.addEventListener('touchend', () => { T.orbit.dragging = false; });

  if (typeof ResizeObserver !== 'undefined') {
    const ro = new ResizeObserver(() => {
      renderer.setSize(cont.clientWidth, cont.clientHeight);
      camera.aspect = cont.clientWidth/cont.clientHeight;
      camera.updateProjectionMatrix();
    });
    ro.observe(cont);
  }

  animateGarage();
}

function applyOrbitCamera(camera) {
  const r = T.orbit.radius;
  camera.position.set(
    r * Math.sin(T.orbit.phi) * Math.cos(T.orbit.theta),
    r * Math.cos(T.orbit.phi),
    r * Math.sin(T.orbit.phi) * Math.sin(T.orbit.theta)
  );
  camera.lookAt(0, 0.6, 0);
}

function setCameraPreset(name) {
  switch(name) {
    case 'orbit':    break;
    case 'auto':     break;
    case 'lowfront': T.orbit.theta = Math.PI*0.05; T.orbit.phi = Math.PI*0.45; T.orbit.radius = 6; break;
    case 'topdown':  T.orbit.theta = Math.PI*0.25; T.orbit.phi = 0.18; T.orbit.radius = 9; break;
    case 'cinema':   T.orbit.theta = Math.PI*0.85; T.orbit.phi = Math.PI*0.4; T.orbit.radius = 8; break;
  }
}

function buildLights() {
  const THREE = THREEx, scene = T.scene;
  const amb = new THREE.AmbientLight(0xffffff, 0.3);
  scene.add(amb); T.parts.amb = amb;

  const sp = new THREE.SpotLight(0xffffff, 2.0, 30, Math.PI/4, 0.4, 1);
  sp.position.set(0, 9, 0);
  sp.castShadow = true;
  sp.shadow.mapSize.width = 1024; sp.shadow.mapSize.height = 1024;
  scene.add(sp); T.parts.spot = sp;

  const mv = new THREE.SpotLight(0xff2a6d, 1.4, 22, Math.PI/5, 0.5, 1);
  mv.position.set(4, 6, 4);
  scene.add(mv); T.parts.mv = mv;

  const fill = new THREE.PointLight(0x05d9e8, 0.5, 18);
  fill.position.set(-5, 3, -4);
  scene.add(fill); T.parts.fill = fill;

  const neon = new THREE.PointLight(0xff2a6d, 0, 6);
  neon.position.set(0, 0.05, 0);
  scene.add(neon); T.parts.neon = neon;
}

function buildGarage() {
