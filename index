  pointer-events: none;
  background:
    radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.5) 100%);
  z-index: 2;
}

.hud-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  padding: 14px 18px;
