      );
      cl.position.set(0.9, 0.95 + carYOffset(), 0);
      g.add(cl);
      const eng = new THREE.Mesh(
        new THREE.BoxGeometry(1.0, 0.4, 0.8),
        new THREE.MeshStandardMaterial({ color: 0x444444, metalness:0.8, roughness:0.3 })
      );
      eng.position.set(0.9, 0.7 + carYOffset(), 0);
      g.add(eng);
      const turbo = new THREE.Mesh(
        new THREE.CylinderGeometry(0.18, 0.18, 0.4, 24),
