  audState.playing = false;
}
function restartAudio() {
  stopAudio();
  playAudio();
}

function makeImpulse(ctx, duration, decay) {
  const rate = ctx.sampleRate;
  const length = rate * duration;
  const impulse = ctx.createBuffer(2, length, rate);
  for (let c = 0; c < 2; c++) {
    const ch = impulse.getChannelData(c);
    for (let i = 0; i < length; i++) {
      ch[i] = (Math.random()*2 - 1) * Math.pow(1 - i/length, decay);
    }
  }
  return impulse;
}

function makeDistortionCurve(amount) {
  const n = 256;
  const curve = new Float32Array(n);
  const k = amount;
  for (let i = 0; i < n; i++) {
    const x = (i*2/n) - 1;
    curve[i] = ((3 + k)*x*20*Math.PI/180) / (Math.PI + k*Math.abs(x));
  }
  return curve;
}

function playAudio() {
  if (!audState.buffer || !audState.ctx) return alert('Load audio first');
  stopAudio();
  const ctx = audState.ctx;
  const src = ctx.createBufferSource();
  src.buffer = audState.buffer;
  src.playbackRate.value = audState.rate;
  const gainNode = ctx.createGain();
  gainNode.gain.value = audState.gainVal;
  const analyser = ctx.createAnalyser();
  analyser.fftSize = 1024;

  let chain = src;
  const fxInt = audState.intensity;

  switch(audState.filter) {
    case 'ENGINE REV': {
      const lfo = ctx.createOscillator();
      lfo.frequency.value = 8 + fxInt * 18;
      const lfoG = ctx.createGain();
      lfoG.gain.value = 0.4 + fxInt * 0.6;
      const mod = ctx.createGain();
      mod.gain.value = 1;
      lfo.connect(lfoG); lfoG.connect(mod.gain);
      chain.connect(mod);
      chain = mod;
      lfo.start();
      audState.lfo = lfo;
      break;
    }
    case 'EXHAUST ECHO': {
      const delay = ctx.createDelay();
      delay.delayTime.value = 0.2 + fxInt * 0.4;
      const fb = ctx.createGain();
      fb.gain.value = 0.4 + fxInt * 0.4;
      const dry = ctx.createGain(); dry.gain.value = 1;
      const wet = ctx.createGain(); wet.gain.value = fxInt;
      chain.connect(dry);
      chain.connect(delay);
      delay.connect(fb); fb.connect(delay);
      delay.connect(wet);
      const merge = ctx.createGain();
      dry.connect(merge); wet.connect(merge);
      chain = merge;
      break;
    }
    case 'DOPPLER': {
      const pitchShift = ctx.createGain(); pitchShift.gain.value = 1;
      src.playbackRate.setValueAtTime(0.6, ctx.currentTime);
      src.playbackRate.linearRampToValueAtTime(1.5, ctx.currentTime + 2);
      src.playbackRate.linearRampToValueAtTime(audState.rate, ctx.currentTime + 3.5);
      break;
    }
    case 'TUNNEL REVERB': {
      const conv = ctx.createConvolver();
      conv.buffer = makeImpulse(ctx, 3.5, 2);
      const dry = ctx.createGain(); dry.gain.value = 1 - fxInt*0.5;
      const wet = ctx.createGain(); wet.gain.value = fxInt;
      chain.connect(dry); chain.connect(conv); conv.connect(wet);
      const merge = ctx.createGain();
      dry.connect(merge); wet.connect(merge);
      chain = merge;
      break;
    }
    case 'SUB BOOST': {
      const low = ctx.createBiquadFilter();
      low.type = 'lowshelf';
      low.frequency.value = 200;
      low.gain.value = 8 + fxInt*20;
      chain.connect(low);
      chain = low;
      break;
    }
    case 'VINYL LO-FI': {
      const low = ctx.createBiquadFilter();
      low.type = 'lowpass'; low.frequency.value = 3500 - fxInt*1500;
      const hi = ctx.createBiquadFilter();
      hi.type = 'highpass'; hi.frequency.value = 80 + fxInt*120;
      chain.connect(low); low.connect(hi);
      // crackle
      const noise = ctx.createBufferSource();
      const buf = ctx.createBuffer(1, ctx.sampleRate * 2, ctx.sampleRate);
      const ch = buf.getChannelData(0);
      for (let i = 0; i < ch.length; i++) ch[i] = Math.random() < 0.01 ? (Math.random()-0.5) : 0;
      noise.buffer = buf; noise.loop = true;
      const ng = ctx.createGain(); ng.gain.value = fxInt * 0.3;
      noise.connect(ng); ng.connect(gainNode);
      noise.start();
      chain = hi;
      break;
    }
    case 'DRIFT SCREECH': {
      const osc = ctx.createOscillator();
      osc.type = 'sawtooth';
      osc.frequency.value = 1200 + fxInt*1800;
      const og = ctx.createGain(); og.gain.value = fxInt * 0.08;
      osc.connect(og); og.connect(gainNode);
      osc.start();
      break;
    }
    case 'RADIO AM': {
      const low = ctx.createBiquadFilter();
      low.type = 'bandpass';
      low.frequency.value = 1600 + fxInt*800;
      low.Q.value = 4 + fxInt*4;
      const dist = ctx.createWaveShaper();
      dist.curve = makeDistortionCurve(50 + fxInt*200);
      chain.connect(low); low.connect(dist);
      chain = dist;
      break;
    }
    case 'MEGAPHONE': {
      const bp = ctx.createBiquadFilter();
      bp.type = 'bandpass'; bp.frequency.value = 1900; bp.Q.value = 1.5;
      const dist = ctx.createWaveShaper();
      dist.curve = makeDistortionCurve(120 + fxInt*200);
      chain.connect(bp); bp.connect(dist);
      chain = dist;
      break;
    }
    case 'DISTORTION': {
      const dist = ctx.createWaveShaper();
      dist.curve = makeDistortionCurve(50 + fxInt*450);
      dist.oversample = '4x';
      chain.connect(dist);
      chain = dist;
      break;
    }
    case 'PHASER': {
      const ap = ctx.createBiquadFilter();
      ap.type = 'allpass'; ap.frequency.value = 800;
      const lfo = ctx.createOscillator();
      lfo.frequency.value = 0.5 + fxInt*2;
      const lfoG = ctx.createGain(); lfoG.gain.value = 600 + fxInt*1200;
      lfo.connect(lfoG); lfoG.connect(ap.frequency);
      chain.connect(ap);
      chain = ap;
      lfo.start();
      break;
    }
    case '8D PAN': {
      const pan = ctx.createStereoPanner();
      const lfo = ctx.createOscillator();
      lfo.frequency.value = 0.3 + fxInt*1.2;
      const lfoG = ctx.createGain(); lfoG.gain.value = 0.95;
      lfo.connect(lfoG); lfoG.connect(pan.pan);
      chain.connect(pan);
      chain = pan;
      lfo.start();
      break;
    }
  }
  chain.connect(gainNode);
  gainNode.connect(analyser);
  analyser.connect(ctx.destination);
  audState.source = src;
  audState.gain = gainNode;
  audState.analyser = analyser;
  src.start();
  audState.playing = true;
  src.onended = () => { audState.playing = false; };
  beep(880, 0.06, 'square', 0.05);
}

/* Spectrum visualizer (RPM-meter style) */
const audVis = document.getElementById('audVis');
const audVisCtx = audVis.getContext('2d');
function tickAudVis() {
  audVisCtx.fillStyle = 'rgba(5,5,7,0.4)';
  audVisCtx.fillRect(0, 0, audVis.width, audVis.height);

  // baseline grid
  audVisCtx.strokeStyle = '#1a1a26';
  audVisCtx.lineWidth = 1;
  for (let i = 0; i < 10; i++) {
    audVisCtx.beginPath();
    audVisCtx.moveTo(0, i * audVis.height / 10);
    audVisCtx.lineTo(audVis.width, i * audVis.height / 10);
    audVisCtx.stroke();
  }

  if (audState.analyser) {
    const a = audState.analyser;
    const data = new Uint8Array(a.frequencyBinCount);
    a.getByteFrequencyData(data);
    const bars = 64;
    const bw = audVis.width / bars;
    let avg = 0;
    for (let i = 0; i < bars; i++) {
      const v = data[i] / 255;
      avg += v;
      const bh = v * audVis.height * 0.95;
      const grad = audVisCtx.createLinearGradient(0, audVis.height, 0, audVis.height - bh);
      grad.addColorStop(0, '#05d9e8');
      grad.addColorStop(0.5, '#ffd23f');
      grad.addColorStop(1, '#ff2a6d');
      audVisCtx.fillStyle = grad;
      audVisCtx.fillRect(i*bw + 1, audVis.height - bh, bw - 2, bh);
    }
    avg /= bars;
    // RPM needle text
    audVisCtx.fillStyle = '#05d9e8';
    audVisCtx.font = 'bold 14px JetBrains Mono';
    audVisCtx.fillText('RPM: ' + Math.floor(avg * 9000).toString().padStart(4, '0'), 10, 18);
    audVisCtx.fillText('FILTER: ' + (audState.filter || 'NONE'), 10, audVis.height - 8);
  } else {
    audVisCtx.fillStyle = '#2a2a3a';
    audVisCtx.font = 'bold 14px JetBrains Mono';
    audVisCtx.fillText('// AWAITING SIGNAL', 14, audVis.height/2);
  }
  requestAnimationFrame(tickAudVis);
}
tickAudVis();

