function buildCarWindows(g) {
  const THREE = THREEx;
  const tcol = new THREE.Color(T.tintColor);
  const opacity = 0.15 + T.tintDark * 0.7;
  const wsMat = new THREE.MeshStandardMaterial({
    color: tcol, metalness: 0.4 + T.tintRefl*0.5,
    roughness: 0.05, transparent: true, opacity: opacity
  });
  const ws = new THREE.Mesh(new THREE.BoxGeometry(0.04, 0.5, 1.4), wsMat);
  ws.position.set(0.55, 1.13 + carYOffset(), 0);
  ws.rotation.z = -0.4;
  g.add(ws);
  const rw = new THREE.Mesh(new THREE.BoxGeometry(0.04, 0.5, 1.4), wsMat);
  rw.position.set(-1.05, 1.18 + carYOffset(), 0);
  rw.rotation.z = 0.45;
  g.add(rw);
  for (const z of [0.78, -0.78]) {
    const side = new THREE.Mesh(new THREE.BoxGeometry(1.5, 0.34, 0.03), wsMat);
    side.position.set(-0.25, 1.27 + carYOffset(), z);
    g.add(side);
  }
  T.parts.windows = wsMat;
}

function applyTint() {
  if (T.parts.windows) {
    T.parts.windows.color.set(T.tintColor);
    T.parts.windows.opacity = 0.15 + T.tintDark * 0.7;
    T.parts.windows.metalness = 0.4 + T.tintRefl * 0.5;
    T.parts.windows.needsUpdate = true;
  }
}

function buildCarSpoiler(g) {
  const THREE = THREEx;
  const m = new THREE.MeshStandardMaterial({ color: T.spoilerColor, metalness: 0.4, roughness: 0.3 });
  const wh = T.wingHeight;
  switch(T.spoilerType) {
    case 'none': return;
    case 'lip': {
      const l = new THREE.Mesh(new THREE.BoxGeometry(0.15, 0.04, 1.4), m);
      l.position.set(-1.9, 1.0 + carYOffset(), 0);
      g.add(l); break;
    }
    case 'duck': {
      const d = new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.12, 1.4), m);
      d.position.set(-1.85, 1.07 + carYOffset(), 0);
      d.rotation.z = -0.2;
      g.add(d); break;
    }
    case 'wing': {
      for (const z of [-0.5, 0.5]) {
        const strut = new THREE.Mesh(new THREE.BoxGeometry(0.06, 0.32*wh, 0.06), m);
        strut.position.set(-1.85, 1.18 + carYOffset() + 0.16*wh, z);
        g.add(strut);
      }
      const wing = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.04, 1.5), m);
      wing.position.set(-1.85, 1.18 + carYOffset() + 0.32*wh, 0);
      g.add(wing);
      break;
    }
    case 'gt': {
      for (const z of [-0.55, 0.55]) {
        const strut = new THREE.Mesh(new THREE.BoxGeometry(0.08, 0.5*wh, 0.08), m);
        strut.position.set(-1.85, 1.25 + carYOffset() + 0.25*wh, z);
        g.add(strut);
      }
      const wing = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.06, 1.7), m);
      wing.position.set(-1.85, 1.25 + carYOffset() + 0.5*wh, 0);
      g.add(wing);
      for (const z of [-0.83, 0.83]) {
        const ep = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.3, 0.04), m);
        ep.position.set(-1.85, 1.25 + carYOffset() + 0.5*wh, z);
        g.add(ep);
      }
      break;
    }
    case 'track': {
      for (const z of [-0.6, 0.6]) {
        const strut = new THREE.Mesh(new THREE.BoxGeometry(0.05, 0.6*wh, 0.05), m);
        strut.position.set(-1.7, 1.3 + carYOffset() + 0.3*wh, z);
        strut.rotation.z = -0.4;
        g.add(strut);
      }
      const wing = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.08, 1.9), m);
      wing.position.set(-1.95, 1.3 + carYOffset() + 0.55*wh, 0);
      wing.rotation.z = 0.06;
      g.add(wing);
      break;
    }
  }
}

function buildCarHeadlights(g) {
  const THREE = THREEx;
  const on = T.headlight !== 'off';
  const colors = { halogen: 0xfff2c4, xenon: 0xeaf4ff, led: 0xffffff };
  const col = colors[T.headlight] || 0xfff2c4;
  if (T.headlight === 'led') {
    const m = new THREE.MeshStandardMaterial({ color: col, emissive: col, emissiveIntensity: on ? 1.5 : 0 });
    for (const z of [-0.5, 0.5]) {
      const bar = new THREE.Mesh(new THREE.BoxGeometry(0.05, 0.04, 0.5), m);
      bar.position.set(1.81, 0.72 + carYOffset(), z);
      g.add(bar);
    }
  } else {
    const m = new THREE.MeshStandardMaterial({ color: col, emissive: col, emissiveIntensity: on ? 1.0 : 0 });
    for (const z of [-0.55, 0.55]) {
      const lamp = new THREE.Mesh(new THREE.BoxGeometry(0.08, 0.18, 0.28), m);
      lamp.position.set(1.81, 0.72 + carYOffset(), z);
      g.add(lamp);
    }
  }
}

function buildCarTaillights(g) {
  const THREE = THREEx;
  const m = new THREE.MeshStandardMaterial({ color: 0xff0033, emissive: 0xff2244, emissiveIntensity: 0.8 });
  for (const z of [-0.55, 0.55]) {
    const tl = new THREE.Mesh(new THREE.BoxGeometry(0.05, 0.16, 0.32), m);
    tl.position.set(-1.95, 0.78 + carYOffset(), z);
    g.add(tl);
  }
  const bar = new THREE.Mesh(
    new THREE.BoxGeometry(0.03, 0.06, 1.0),
    new THREE.MeshStandardMaterial({ color: 0xff0033, emissive: 0xff0033, emissiveIntensity: 0.6 })
  );
  bar.position.set(-1.95, 0.78 + carYOffset(), 0);
  g.add(bar);
}

function buildCarExhaust(g) {
  const THREE = THREEx;
  const m = new THREE.MeshStandardMaterial({ color: 0x999999, metalness: 1, roughness: 0.2 });
  const isAggro = T.bodyKit === 'aggro' || T.bodyKit === 'wide';
  const pipes = isAggro ? [-0.4, 0.4, -0.55, 0.55] : [-0.4, 0.4];
  for (const z of pipes) {
    const p = new THREE.Mesh(new THREE.CylinderGeometry(0.07, 0.07, 0.12, 16), m);
    p.position.set(-1.95, 0.45 + carYOffset(), z);
    p.rotation.z = Math.PI/2;
    g.add(p);
  }
}

function buildCarBodyKit(g) {
  const THREE = THREEx;
  const mat = T.parts.bodyMat;
  if (T.bodyKit === 'sport' || T.bodyKit === 'aggro' || T.bodyKit === 'wide') {
    const fb = new THREE.Mesh(new THREE.BoxGeometry(0.25, 0.18, 1.7), mat);
    fb.position.set(1.85, 0.43 + carYOffset(), 0);
    g.add(fb);
    const rb = new THREE.Mesh(new THREE.BoxGeometry(0.25, 0.18, 1.7), mat);
    rb.position.set(-1.85, 0.43 + carYOffset(), 0);
    g.add(rb);
  }
  if (T.bodyKit === 'aggro' || T.bodyKit === 'wide') {
    const ch = new THREE.Mesh(
      new THREE.BoxGeometry(0.6, 0.03, 1.9),
      new THREE.MeshStandardMaterial({ color: 0x111111, metalness:0.2, roughness:0.6 })
    );
    ch.position.set(1.85, 0.3 + carYOffset(), 0);
    g.add(ch);
  }
  if (T.sideSkirt !== 'none' || T.bodyKit === 'aggro' || T.bodyKit === 'wide') {
    const drop = T.sideSkirt === 'extreme' ? 0.15 : (T.sideSkirt === 'low' ? 0.08 : 0.05);
    for (const z of [0.88, -0.88]) {
      const sk = new THREE.Mesh(new THREE.BoxGeometry(3.0, drop, 0.08), mat);
      sk.position.set(0, 0.4 - drop/2 + carYOffset(), z);
      g.add(sk);
    }
  }
  if (T.frontLip === 'splitter') {
    const sp = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.03, 1.9), new THREE.MeshStandardMaterial({ color: 0x080808, metalness:0.3, roughness:0.5 }));
    sp.position.set(1.95, 0.33 + carYOffset(), 0);
    g.add(sp);
  } else if (T.frontLip === 'canard') {
    for (const z of [0.85, -0.85]) {
      const c = new THREE.Mesh(new THREE.BoxGeometry(0.25, 0.02, 0.18), new THREE.MeshStandardMaterial({ color: 0x080808 }));
      c.position.set(1.85, 0.42 + carYOffset(), z);
      c.rotation.y = (z > 0 ? -0.2 : 0.2);
      g.add(c);
    }
  }
}

function buildCarWheels(g) {
  const THREE = THREEx;
  const tireR = 0.32 + (T.tireSize - 15) * 0.04;
  const tireW = 0.32 - T.stretch * 0.12;
  const tireMat = new THREE.MeshStandardMaterial({ color: 0x0a0a0a, roughness: 0.85, metalness: 0.05 });
  const rimMat  = new THREE.MeshStandardMaterial({ color: T.rimColor, metalness: 0.9, roughness: 0.2 });
  const camberR = T.camber * Math.PI/180;

  const wheelbaseZ = 0.78 + T.wheelPoke * 0.012;
  const wheelX = [1.15, -1.15];

  wheelX.forEach((x, axleI) => {
    [wheelbaseZ, -wheelbaseZ].forEach(z => {
      const wheelGroup = new THREE.Group();
      wheelGroup.position.set(x, tireR + 0.02 + carYOffset(), z);
      if (axleI === 0) wheelGroup.position.y += T.frontDrop * 0.01;
      else             wheelGroup.position.y += T.rearDrop  * 0.01;
      wheelGroup.rotation.x = Math.PI/2;
      wheelGroup.rotation.z = (z > 0 ? camberR : -camberR);

      const tire = new THREE.Mesh(new THREE.CylinderGeometry(tireR, tireR, tireW, 30), tireMat);
      tire.castShadow = true;
      wheelGroup.add(tire);

      const rim = buildRim(rimMat, tireR, tireW);
      wheelGroup.add(rim);

      const disc = new THREE.Mesh(
        new THREE.CylinderGeometry(tireR*0.7, tireR*0.7, 0.04, 24),
        new THREE.MeshStandardMaterial({ color: 0x666666, metalness: 0.8, roughness: 0.3 })
      );
      disc.position.y = -tireW/2 + 0.04;
      wheelGroup.add(disc);

      const caliper = new THREE.Mesh(
        new THREE.BoxGeometry(tireR*0.45, 0.08, 0.05),
        new THREE.MeshStandardMaterial({ color: 0xff2a6d, metalness: 0.5, roughness: 0.3 })
      );
      caliper.position.set(0, -tireW/2 + 0.05, tireR*0.5);
      wheelGroup.add(caliper);

      g.add(wheelGroup);
    });
  });
}

function buildRim(mat, R, W) {
  const THREE = THREEx;
  const grp = new THREE.Group();
  const center = new THREE.Mesh(new THREE.CylinderGeometry(R*0.85, R*0.85, W+0.005, 32), mat);
  grp.add(center);
  const inner = new THREE.Mesh(
    new THREE.CylinderGeometry(R*0.95, R*0.95, W*0.4, 32),
    new THREE.MeshStandardMaterial({ color: 0x111111, metalness:0.8, roughness:0.3 })
  );
  inner.position.y = W*0.3;
  grp.add(inner);

  switch(T.rim) {
    case '5spoke': {
      for (let i = 0; i < 5; i++) {
        const sp = new THREE.Mesh(new THREE.BoxGeometry(R*1.5, W*0.5, R*0.14), mat);
        sp.rotation.y = i * Math.PI*2/5;
        sp.position.y = W*0.2;
        grp.add(sp);
      }
      break;
    }
    case 'mesh': {
      for (let i = 0; i < 14; i++) {
        const sp = new THREE.Mesh(new THREE.BoxGeometry(R*1.5, W*0.45, R*0.06), mat);
        sp.rotation.y = i * Math.PI/7;
        sp.position.y = W*0.2;
        grp.add(sp);
      }
      break;
    }
    case 'deep': {
      const lip = new THREE.Mesh(
        new THREE.CylinderGeometry(R*0.95, R*0.85, W*0.5, 32),
        new THREE.MeshStandardMaterial({ color: 0xeeeeee, metalness: 1, roughness: 0.05 })
      );
      lip.position.y = W*0.25;
      grp.add(lip);
      for (let i = 0; i < 6; i++) {
        const sp = new THREE.Mesh(new THREE.BoxGeometry(R*1.4, W*0.4, R*0.18), mat);
        sp.rotation.y = i * Math.PI/3;
        sp.position.y = W*0.15;
        grp.add(sp);
      }
      break;
    }
    case 'split': {
      for (let i = 0; i < 6; i++) {
        const sp1 = new THREE.Mesh(new THREE.BoxGeometry(R*1.4, W*0.4, R*0.08), mat);
        const sp2 = new THREE.Mesh(new THREE.BoxGeometry(R*1.4, W*0.4, R*0.08), mat);
        sp1.rotation.y = i*Math.PI/3 - 0.1;
        sp2.rotation.y = i*Math.PI/3 + 0.1;
        sp1.position.y = W*0.2; sp2.position.y = W*0.2;
        grp.add(sp1); grp.add(sp2);
      }
      break;
    }
    case 'turbine': {
      for (let i = 0; i < 9; i++) {
        const sp = new THREE.Mesh(new THREE.BoxGeometry(R*1.5, W*0.45, R*0.18), mat);
        sp.rotation.y = i * Math.PI*2/9;
        sp.rotation.x = 0.3;
        sp.position.y = W*0.18;
        grp.add(sp);
      }
      break;
    }
    case 'blade': {
      for (let i = 0; i < 3; i++) {
        const sp = new THREE.Mesh(new THREE.BoxGeometry(R*1.7, W*0.5, R*0.45), mat);
        sp.rotation.y = i * Math.PI*2/3;
        sp.position.y = W*0.2;
        grp.add(sp);
      }
      break;
    }
  }
  const cap = new THREE.Mesh(new THREE.CylinderGeometry(R*0.2, R*0.2, W*0.55, 16), mat);
  cap.position.y = W*0.28;
  grp.add(cap);

  return grp;
}

function applyEnv() {
  if (!T.scene) return;
  T.scene.background = new THREEx.Color(T.env[1]);
  if (T.parts.floor) T.parts.floor.material.color.set(T.env[3] || '#222230');
  if (T.parts.wall)  T.parts.wall.material.color.set(T.env[3] || '#14141c');
}

function animateGarage() {
  if (!T.scene) return;
  requestAnimationFrame(animateGarage);

  const now = performance.now();
  const dt = (now - T.lastFrame) / 1000;
  T.lastFrame = now;
  T.fps = T.fps * 0.9 + (1/Math.max(dt,0.001))*0.1;
  document.getElementById('hudFps').textContent = 'FPS:' + Math.round(T.fps);
  document.getElementById('hudRpm').textContent = 'RPM:' + String(Math.floor(800 + Math.random()*7800)).padStart(4,'0');

  if (T.cam === 'auto' && !T.orbit.dragging) {
    T.orbit.theta += dt * 0.25;
  } else if (T.cam === 'cinema' && !T.orbit.dragging) {
    T.orbit.theta += dt * 0.4;
    T.orbit.phi = Math.PI*0.36 + Math.sin(now/2000)*0.08;
  }
  applyOrbitCamera(T.camera);

  if (T.parts.mv) {
    T.parts.mv.position.x = Math.cos(now/3000) * 6;
    T.parts.mv.position.z = Math.sin(now/3000) * 6;
    T.parts.mv.target.position.set(0, 0.5, 0);
    T.parts.mv.target.updateMatrixWorld();
  }

  let nc = T.neonColor;
  let nVis = false;
  switch(T.neon) {
    case 'off': break;
    case 'solid': nVis = true; break;
    case 'pulse': nVis = true; break;
    case 'rainbow': {
      nVis = true;
      T.rainbowHue = (T.rainbowHue + 1) % 360;
      nc = `hsl(${T.rainbowHue}, 100%, 55%)`;
      break;
    }
    case 'strobe': nVis = (Math.floor(now / 90) % 2 === 0); break;
  }
  if (T.parts.underglow) {
    const ug = T.parts.underglow;
    if (nVis) {
      let i = T.neonI;
      if (T.neon === 'pulse') i *= 0.6 + 0.4 * Math.sin(now/250);
      ug.material.opacity = i * 0.9;
      ug.material.color.set(nc);
      ug.scale.x = ug.scale.z = T.neonSpread;
    } else {
      ug.material.opacity = 0;
    }
  }
  if (T.parts.neon) {
    T.parts.neon.intensity = nVis ? T.neonI * 6 : 0;
    if (nVis) T.parts.neon.color.set(nc);
  }

  if (T.parts.ring) {
    if (T.neon === 'rainbow' && nVis) {
      T.parts.ring.material.color.set(nc);
    } else {
      T.parts.ring.material.color.set('#05d9e8');
    }
  }

  T.renderer.render(T.scene, T.camera);

  if (Math.floor(now/300) % 4 === 0) updateStatsBox();
}

function updateStatsBox() {
  const box = document.getElementById('statsBox');
  if (!box) return;
  const base = 320;
  let hp = base;
  if (T.hood === 'scoop') hp += 25;
  if (T.hood === 'vent') hp += 15;
  if (T.hood === 'cf') hp += 10;
  if (T.hood === 'clear') hp += 40;
  if (T.bodyKit === 'sport') hp += 20;
  if (T.bodyKit === 'aggro') hp += 60;
  if (T.bodyKit === 'wide') hp += 75;
  if (T.spoilerType === 'wing') hp += 8;
  if (T.spoilerType === 'gt') hp += 25;
  if (T.spoilerType === 'track') hp += 40;
  hp += T.tireSize - 18;

  const tq = Math.round(hp * 0.85);
  const wt = 1380 - (T.bodyKit === 'wide' ? -40 : 0) - (T.hood === 'cf' ? 60 : 0);
  const drag = T.spoilerType === 'gt' ? 0.34 : (T.spoilerType === 'track' ? 0.38 : 0.30);
  const accel = Math.max(2.4, (4.2 - hp/180));

  function bar(v, max) {
    const p = Math.max(0, Math.min(100, (v/max)*100));
    return '<span class="bar"><i style="width:' + p + '%"></i></span>';
  }

  box.innerHTML = '' +
    '<div class="row"><span>POWER</span><b>' + hp + ' HP</b></div>' +
    '<div class="row"><span>TORQUE</span><b>' + tq + ' Nm</b></div>' +
    '<div class="row"><span>WEIGHT</span><b>' + wt + ' kg</b></div>' +
    '<div class="row"><span>DRAG Cd</span><b>' + drag.toFixed(2) + '</b></div>' +
    '<div class="row"><span>0-100 km/h</span><b>' + accel.toFixed(1) + ' s</b></div>' +
    '<div class="row"><span>STANCE</span>' + bar(-T.rideH + (T.frontDrop+T.rearDrop)/-2, 50) + '</div>' +
    '<div class="row"><span>GRIP</span>' + bar(60 + (T.bodyKit==='wide'?20:0) + (T.camber<-5?15:0), 100) + '</div>' +
    '<div class="row"><span>STYLE</span>' + bar(40 + (T.neon!=='off'?20:0) + (T.spoilerType==='gt'?15:0) + (T.hood==='clear'?10:0) + (T.stripe!=='none'?10:0), 100) + '</div>';
}

/* =============================================================
   TEXT BAY
   ============================================================= */
const TEXT_STYLES = ['NEON SIGN','RACING','LICENSE PLATE','SPEEDOMETER','ASCII CAR'];
const textFiltersBox = document.getElementById('textFilters');
let currentTextStyle = 'NEON SIGN';
TEXT_STYLES.forEach((name, i) => {
  const b = document.createElement('button');
  b.className = 'fbtn' + (i === 0 ? ' active' : '');
  b.textContent = name;
  b.addEventListener('click', () => {
    currentTextStyle = name;
    textFiltersBox.querySelectorAll('.fbtn').forEach(x => x.classList.toggle('active', x.textContent === name));
    renderText();
  });
  textFiltersBox.appendChild(b);
});

const textInput = document.getElementById('textInput');
const textRender = document.getElementById('textRender');
textInput.addEventListener('input', renderText);

function renderText() {
  const v = textInput.value || 'GARAGE FX';
  textRender.innerHTML = '';
  switch(currentTextStyle) {
    case 'NEON SIGN': {
      const d = document.createElement('div');
      d.className = 'neon-text';
      d.textContent = v;
      textRender.appendChild(d);
      break;
    }
    case 'RACING': {
      const d = document.createElement('div');
      d.className = 'racing-text';
      d.textContent = v;
      textRender.appendChild(d);
      break;
    }
    case 'LICENSE PLATE': {
      const d = document.createElement('div');
      d.className = 'license-plate';
      d.textContent = v.toUpperCase().substring(0, 10);
      textRender.appendChild(d);
      break;
    }
    case 'SPEEDOMETER': {
      const d = document.createElement('div');
      d.className = 'speedo-text';
      d.textContent = v;
      textRender.appendChild(d);
      break;
    }
    case 'ASCII CAR': {
      const pre = document.createElement('pre');
      pre.className = 'ascii-art';
      pre.textContent =
'    ______________\n' +
'   /|  ' + v.substring(0,8).padEnd(8) + ' |\\\n' +
'  /_|_____________|_\\\n' +
'   | [_]       [_]\n' +
'        ' + v.substring(0,16) + '\n' +
'   .o0===========0o.\n' +
'  ( O )         ( O )\n' +
"   '.'           '.'";
      textRender.appendChild(pre);
      break;
    }
  }
}
renderText();

let speedoT = null;
document.getElementById('textSpeedo').addEventListener('click', () => {
  if (speedoT) { clearInterval(speedoT); speedoT = null; return; }
  let n = 0;
  speedoT = setInterval(() => {
    n = (n + 17) % 999;
    textInput.value = String(n).padStart(3, '0');
    if (currentTextStyle !== 'SPEEDOMETER') {
      currentTextStyle = 'SPEEDOMETER';
      textFiltersBox.querySelectorAll('.fbtn').forEach(x => x.classList.toggle('active', x.textContent === 'SPEEDOMETER'));
    }
    renderText();
  }, 80);
});
</script>
