function loadVideo(file) {
  const url = URL.createObjectURL(file);
  vidSrc.src = url;
  vidSrc.onloadedmetadata = () => {
    const maxW = 880, maxH = 540;
    let w = vidSrc.videoWidth, h = vidSrc.videoHeight;
    const scale = Math.min(maxW / w, maxH / h, 1);
    vidCanvas.width = Math.floor(w * scale);
    vidCanvas.height = Math.floor(h * scale);
    vidEmpty.style.display = 'none';
    vidCanvas.style.display = 'block';
    vidSrc.play();
    if (!vidState.raf) drawVideoLoop();
  };
}

[['sliVBri','bri','lblVBri','%'],['sliVCon','con','lblVCon','%'],['sliVSat','sat','lblVSat','%']]
.forEach(([s, key, lab, suf]) => {
  document.getElementById(s).addEventListener('input', e => {
    vidState[key] = +e.target.value;
    document.getElementById(lab).textContent = e.target.value + suf;
  });
});
document.getElementById('sliVFx').addEventListener('input', e => {
  vidState.fx = +e.target.value / 100;
  document.getElementById('lblVFx').textContent = e.target.value + '%';
});

document.getElementById('vidPlay').addEventListener('click', () => {
  if (vidSrc.src) { vidSrc.play(); if (!vidState.raf) drawVideoLoop(); }
});
document.getElementById('vidPause').addEventListener('click', () => vidSrc.pause());

let prevFrame = null;
let strobeFlag = 0;

function drawVideoLoop() {
  vidState.raf = requestAnimationFrame(drawVideoLoop);
  if (vidSrc.readyState < 2) return;
  const w = vidCanvas.width, h = vidCanvas.height;

  // motion blur trail
  if (vidState.filter === 'MOTION BLUR') {
    vidCtx.fillStyle = `rgba(10,10,15,${0.4 - vidState.fx * 0.35})`;
    vidCtx.fillRect(0, 0, w, h);
  } else if (vidState.filter === 'SLOW-MO') {
    if (vidSrc.playbackRate !== 0.3 + (1 - vidState.fx) * 0.5) {
      try { vidSrc.playbackRate = 0.3 + (1 - vidState.fx) * 0.5; } catch(e){}
    }
  } else if (vidState.filter === 'SPEED RAMP') {
    try { vidSrc.playbackRate = 1 + vidState.fx * 2; } catch(e){}
  } else {
    try { if (vidSrc.playbackRate !== 1) vidSrc.playbackRate = 1; } catch(e){}
  }

  vidCtx.save();
  vidCtx.filter = `brightness(${vidState.bri}%) contrast(${vidState.con}%) saturate(${vidState.sat}%)`;

  if (vidState.filter === 'VHS DASHCAM') {
    // jiggle
    const jx = (Math.random()-0.5)*2;
    const jy = (Math.random()-0.5)*2;
    vidCtx.drawImage(vidSrc, jx, jy, w, h);
  } else {
    vidCtx.drawImage(vidSrc, 0, 0, w, h);
  }
  vidCtx.restore();

  // post effects
  switch(vidState.filter) {
    case 'ANAMORPHIC': {
      vidCtx.globalCompositeOperation = 'screen';
      const g = vidCtx.createLinearGradient(0, h*0.4, w, h*0.4);
      g.addColorStop(0, 'rgba(5,217,232,0)');
      g.addColorStop(0.5, `rgba(5,217,232,${0.4*vidState.fx})`);
      g.addColorStop(1, 'rgba(5,217,232,0)');
      vidCtx.fillStyle = g;
      vidCtx.fillRect(0, h*0.4 - 3, w, 6);
      vidCtx.globalCompositeOperation = 'source-over';
      break;
    }
    case 'FORZA GRADE': {
      vidCtx.globalCompositeOperation = 'overlay';
      const g = vidCtx.createLinearGradient(0, 0, 0, h);
      g.addColorStop(0, `rgba(255,180,80,${0.3*vidState.fx})`);
      g.addColorStop(1, `rgba(0,40,80,${0.3*vidState.fx})`);
      vidCtx.fillStyle = g;
      vidCtx.fillRect(0, 0, w, h);
      vidCtx.globalCompositeOperation = 'source-over';
      break;
    }
    case 'F&F TINT': {
      vidCtx.globalCompositeOperation = 'multiply';
      vidCtx.fillStyle = `rgba(120,200,80,${0.25*vidState.fx})`;
      vidCtx.fillRect(0, 0, w, h);
      vidCtx.globalCompositeOperation = 'source-over';
      break;
    }
    case 'POLICE STROBE': {
      strobeFlag = (strobeFlag + 1) % 16;
      const t = Math.floor(strobeFlag/4);
      vidCtx.globalCompositeOperation = 'screen';
      if (t === 0) {
        vidCtx.fillStyle = `rgba(0,0,255,${0.5*vidState.fx})`;
        vidCtx.fillRect(0, 0, w/2, h);
      } else if (t === 2) {
        vidCtx.fillStyle = `rgba(255,0,0,${0.5*vidState.fx})`;
        vidCtx.fillRect(w/2, 0, w/2, h);
      }
      vidCtx.globalCompositeOperation = 'source-over';
      break;
    }
    case 'VHS DASHCAM': {
      // scanlines
      vidCtx.fillStyle = `rgba(0,0,0,${0.3*vidState.fx})`;
      for (let y = 0; y < h; y += 4) vidCtx.fillRect(0, y, w, 1);
      // hud
      vidCtx.fillStyle = '#ff2a6d';
      vidCtx.font = 'bold 16px JetBrains Mono';
      const t = new Date();
      vidCtx.fillText('● REC  ' + t.toTimeString().slice(0,8), 12, 24);
      vidCtx.fillText('GPS: 48.14N 17.10E', 12, h - 14);
      vidCtx.fillText('SPD: ' + Math.floor(80 + Math.random()*40) + ' km/h', w - 180, h - 14);
      break;
    }
    case 'HEAT HAZE': {
      // pixel shimmer
      const slice = 10;
      for (let i = 0; i < h; i += slice) {
        const off = Math.sin(Date.now()/200 + i/20) * 3 * vidState.fx;
        const s = vidCtx.getImageData(0, i, w, slice);
        vidCtx.putImageData(s, off, i);
      }
      break;
    }
    case 'CHROMATIC AB': {
      const off = Math.floor(2 + vidState.fx * 8);
      const data = vidCtx.getImageData(0, 0, w, h);
      const out = vidCtx.createImageData(w, h);
      const d = data.data, o = out.data;
      for (let y = 0; y < h; y++) {
        for (let x = 0; x < w; x++) {
          const i = (y*w+x)*4;
          const iR = (y*w+Math.min(w-1, Math.max(0, x+off)))*4;
          const iB = (y*w+Math.min(w-1, Math.max(0, x-off)))*4;
          o[i] = d[iR]; o[i+1] = d[i+1]; o[i+2] = d[iB+2]; o[i+3] = 255;
        }
      }
      vidCtx.putImageData(out, 0, 0);
      break;
    }
  }
}

