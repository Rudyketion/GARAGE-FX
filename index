/* ---------- BOOT SCREEN ---------- */
const bootLog = document.getElementById('bootLog');
const bootFill = document.getElementById('bootFill');
const bootPct = document.getElementById('bootPct');
const bootEl = document.getElementById('boot');

const bootMessages = [
  ['INIT', 'ECU subsystem online'],
  ['OK', 'Loading IMAGE BAY drivers'],
  ['OK', 'Loading AUDIO BAY DSP modules'],
  ['OK', 'Loading VIDEO BAY codec pipeline'],
  ['OK', 'Loading 3D BAY WebGL renderer'],
  ['OK', 'Loading TEXT BAY font cache'],
  ['WARN', 'Cooling fan rpm low - acceptable'],
  ['OK', 'Hazard lights operational'],
  ['OK', 'Neon underglow primed'],
  ['OK', 'Garage door servo unlocked'],
  ['OK', 'Diagnostic port ready']
];
let bootIdx = 0, bootProgress = 0, bootDone = false;
function appendBootLine(tag, msg) {
  const line = document.createElement('div');
  line.className = 'line';
  const cls = tag === 'OK' ? 'ok' : (tag === 'WARN' ? 'warn' : 'err');
  line.innerHTML = `<span class="${cls}">[${tag.padEnd(4)}]</span> ${msg}`;
  bootLog.appendChild(line);
  while (bootLog.children.length > 11) bootLog.removeChild(bootLog.firstChild);
}
function tickBoot() {
  if (bootDone) return;
  bootProgress += 2 + Math.random() * 4;
  if (bootProgress > 100) bootProgress = 100;
  bootFill.style.width = bootProgress + '%';
  bootPct.textContent = Math.floor(bootProgress) + '%';
  if (Math.random() < 0.4 && bootIdx < bootMessages.length) {
    const [tag, msg] = bootMessages[bootIdx++];
    appendBootLine(tag, msg);
    beep(800 + Math.random()*400, 0.02, 'square', 0.025);
  }
  if (bootProgress >= 100 && bootIdx >= bootMessages.length) {
    finishBoot();
  } else {
    setTimeout(tickBoot, 120 + Math.random()*180);
  }
}
function finishBoot() {
  if (bootDone) return;
  bootDone = true;
  appendBootLine('OK', 'BOOT COMPLETE - WELCOME');
  setTimeout(() => {
    bootEl.classList.add('gone');
    engineStart();
  }, 500);
}
document.getElementById('boot').addEventListener('click', () => {
  bootProgress = 100;
  while (bootIdx < bootMessages.length) {
    appendBootLine(...bootMessages[bootIdx++]);
  }
  bootFill.style.width = '100%';
  bootPct.textContent = '100%';
  finishBoot();
});
setTimeout(tickBoot, 300);

/* ---------- PARTICLE BG ---------- */
const pCanvas = document.getElementById('particles');
const pCtx = pCanvas.getContext('2d');
let particles = [];
let activity = 0;

function resizeCanvas() {
  pCanvas.width = window.innerWidth;
  pCanvas.height = window.innerHeight;
}
resizeCanvas();
window.addEventListener('resize', resizeCanvas);

function spawnParticles() {
  particles = [];
  const n = 70;
  for (let i = 0; i < n; i++) {
    particles.push({
      x: Math.random() * pCanvas.width,
      y: Math.random() * pCanvas.height,
      vx: (Math.random() - 0.5) * 0.4,
      vy: (Math.random() - 0.5) * 0.4,
      r: Math.random() * 1.4 + 0.4,
      c: Math.random() < 0.5 ? '#ff2a6d' : '#05d9e8'
    });
  }
}
spawnParticles();

function tickParticles() {
  pCtx.fillStyle = 'rgba(10,10,15,0.18)';
  pCtx.fillRect(0, 0, pCanvas.width, pCanvas.height);
  const speedBoost = 1 + activity * 4;
  for (const p of particles) {
    p.x += p.vx * speedBoost;
    p.y += p.vy * speedBoost;
    if (p.x < 0) p.x = pCanvas.width;
    if (p.x > pCanvas.width) p.x = 0;
    if (p.y < 0) p.y = pCanvas.height;
    if (p.y > pCanvas.height) p.y = 0;
    pCtx.beginPath();
    pCtx.fillStyle = p.c;
    pCtx.shadowBlur = 8;
    pCtx.shadowColor = p.c;
    pCtx.arc(p.x, p.y, p.r * (1 + activity), 0, Math.PI*2);
    pCtx.fill();
  }
  pCtx.shadowBlur = 0;
  activity *= 0.96;
  requestAnimationFrame(tickParticles);
}
tickParticles();

document.addEventListener('mousemove', () => { activity = Math.min(1, activity + 0.04); });
document.addEventListener('click', () => { activity = Math.min(1, activity + 0.4); });

