/* GARAGE DOOR open animation */
.garage-door {
  position: absolute; inset: 0;
  z-index: 4;
  pointer-events: none;
  background:
    repeating-linear-gradient(
      0deg,
      #2a2a30 0px, #2a2a30 30px,
      #1a1a20 30px, #1a1a20 32px
    );
  border-top: 6px solid #444;
  border-bottom: 6px solid #444;
  transform-origin: top;
  transition: transform 1.4s cubic-bezier(.5, 0, .3, 1);
}
.garage-door.open { transform: scaleY(0); }
.garage-door::after {
  content: "GARAGE FX — OPENING...";
