"use strict";

/* ---------- AUDIO UTIL: tiny synth for UI sounds ---------- */
let uiAudioCtx = null;
function ensureUiAudio() {
  if (!uiAudioCtx) {
    try { uiAudioCtx = new (window.AudioContext || window.webkitAudioContext)(); } catch(e) {}
  }
  return uiAudioCtx;
}
function beep(freq=440, dur=0.06, type='square', vol=0.06) {
  const ctx = ensureUiAudio(); if (!ctx) return;
  const o = ctx.createOscillator(); const g = ctx.createGain();
  o.type = type; o.frequency.value = freq;
  g.gain.value = vol;
  o.connect(g); g.connect(ctx.destination);
  o.start();
  g.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + dur);
  o.stop(ctx.currentTime + dur);
}
function engineStart() {
  const ctx = ensureUiAudio(); if (!ctx) return;
  const o = ctx.createOscillator(); const g = ctx.createGain();
  o.type = 'sawtooth';
  o.frequency.setValueAtTime(60, ctx.currentTime);
  o.frequency.exponentialRampToValueAtTime(220, ctx.currentTime + 0.9);
  o.frequency.exponentialRampToValueAtTime(120, ctx.currentTime + 1.4);
  g.gain.setValueAtTime(0.15, ctx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 1.5);
  o.connect(g); g.connect(ctx.destination);
  o.start(); o.stop(ctx.currentTime + 1.5);
}

document.addEventListener('click', (e) => {
